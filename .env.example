## Frontend (Vite)
# URL del despliegue Web App de Apps Script para Limpiezas (CLEAN_STATUS)
# Ejemplo:
# VITE_CLEANS_APPS_SCRIPT_URL="https://script.google.com/macros/s/XXXX/exec"
VITE_CLEANS_APPS_SCRIPT_URL=

# (Opcional) otras URLs si quieres unificar configuración
# VITE_ACCOMMODATIONS_APPS_SCRIPT_URL=
# VITE_WORKERS_APPS_SCRIPT_URL=
# VITE_INCIDENCIAS_APPS_SCRIPT_URL=
# VITE_ENTREGA_LLAVES_APPS_SCRIPT_URL=

## Supabase (Autenticación y Roles)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

